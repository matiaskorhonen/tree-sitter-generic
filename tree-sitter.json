{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "generic",
      "camelcase": "Generic",
      "title": "Generic",
      "scope": "source.generic",
      "file-types": [],
      "injection-regex": "^generic$",
      "class-name": "TreeSitterGeneric"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "A tree-sitter grammar for generic syntax highlighting",
    "authors": [],
    "links": {
      "repository": "https://github.com/user/tree-sitter-generic",
      "funding": ""
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": true,
    "zig": false
  }
}
